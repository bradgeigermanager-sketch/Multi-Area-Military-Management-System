{
  "$schema": "https://json-schema.org",
  "$id": "https://hq.mil",
  "type": "object",
  "required": ["component_metadata", "frequency_mhz", "encryption_key_id", "check_in_interval_mins"],
  "additionalProperties": false,
  "properties": {
    "component_metadata": {
      "type": "object",
      "required": ["uid", "classification", "label", "author"],
      "properties": {
        "uid": { "type": "string", "const": "CMP-COM-0045" },
        "classification": { "type": "string", "enum": ["UNCLASSIFIED", "CONFIDENTIAL", "SECRET"] },
        "label": { "type": "string" },
        "author": { "type": "string" }
      }
    },
    "frequency_mhz": { "type": "number", "minimum": 30.0, "maximum": 512.0 },
    "encryption_key_id": { "type": "string", "pattern": "^KEY-[A-Z0-9]{4}$" },
    "check_in_interval_mins": { "type": "integer", "minimum": 5 }
  }
}
